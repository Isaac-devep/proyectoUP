    <!-- PORTADA -->
    <div style="text-align: center; margin-top: 150px;">
        <h1 style="border:none; font-size: 36pt; color:#2c3e50;">PLATAFORMA SAGA</h1>
        <h2 style="color: #7f8c8d;">Documentación Oficial</h2>
        <br><br><br>
        <p style="font-size: 14pt;">Contiene:</p>
        <p style="font-size: 18pt; font-weight: bold; color: #2980b9;">1. Manual de Usuario</p>
        <p style="font-size: 18pt; font-weight: bold; color: #2980b9;">2. Manual del Sistema (Técnico)</p>
        <br><br><br>
        <p>Vigencia: 2026</p>
